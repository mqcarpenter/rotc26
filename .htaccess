# Deny direct access to config.php and any stray backup/editor files that
# might get created next to it (config.php~, config.php.bak, config.php.save).
# These would otherwise be served as plain text instead of executed as PHP,
# which is how a real API key ends up leaked.
<FilesMatch "^config\.php(~|\.bak|\.save)?$|^\.env">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# templates/ and includes/ are PHP fragments meant to be include()'d by
# index.php etc — they reference variables the caller sets up first, so
# hitting them directly throws PHP notices instead of a real page. Block
# direct requests; index.php and friends still include() them fine since
# that's a filesystem read, not an HTTP request.
RewriteEngine On
RewriteRule ^(templates|includes)/ - [F,L]

# Clean URLs for the tab bar: /standings -> standings.php, etc. Only
# kicks in when no real file/directory matches the request, so
# /assets/mfl26.css and /api/matchup-ticker.php are untouched.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)/?$ $1.php [L,QSA]
